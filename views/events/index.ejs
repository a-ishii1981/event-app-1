<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8"><meta http-equiv="Content-Type" content="text/html; charset=UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
  <title><%= workspace.name %> | イベント記録</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700&family=DM+Mono:wght@500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="app-container">
    <header class="page-header">
      <a href="/" class="back-btn">? 戻る</a>
      <div class="header-center">
        <div class="header-badge workspace-<%= workspace.type %>">
          <%= workspace.type === 'business' ? '?? 事業' : '?? バイト' %>
        </div>
        <h1 class="page-title"><%= workspace.name %></h1>
      </div>
    </header>
    <main class="page-main">
      <a href="/events/new/<%= workspace.id %>" class="btn btn-primary btn-full">＋ 新しいイベントを記録する</a>
      <section class="section">
        <% if (events.length === 0) { %>
        <div class="empty-state">
          <div class="empty-icon">??</div>
          <p>まだイベントがありません</p>
          <p class="empty-sub">上のボタンから記録を始めましょう</p>
        </div>
        <% } else { %>
        <div class="event-list">
          <% events.forEach(ev => { %>
          <a href="/events/<%= ev.id %>" class="event-card">
            <div class="event-date"><%= new Date(ev.date).toLocaleDateString('ja-JP', {month:'numeric', day:'numeric', weekday:'short'}) %></div>
            <div class="event-info">
              <div class="event-name"><%= ev.name %></div>
              <% if (ev.location) { %><div class="event-location">?? <%= ev.location %></div><% } %>
            </div>
            <div class="event-arrow">?</div>
          </a>
          <% }) %>
        </div>
        <% } %>
      </section>
    </main>
  </div>
  <script src="/js/app.js"></script>
</body>
</html>


